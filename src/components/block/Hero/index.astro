---
import { Image } from "astro:assets"

import AppSection from "@/layouts/app-section.astro"
import heroBg from "../../../../Design Reference/hero-bg.png"
import almaRetro from "../../../../Design Reference/alma-retro.png"
---

<AppSection
  wrapperClass="h-svh overflow-hidden text-event-primary lg:h-auto"
  class="relative grid h-svh overflow-visible px-0 py-0! lg:h-auto lg:min-h-[760px]"
>
  <Image
    src={heroBg}
    alt=""
    aria-hidden="true"
    class="pointer-events-none absolute top-8 left-1/2 h-full w-full max-w-none -translate-x-1/2 [mask-image:linear-gradient(to_right,transparent,rgba(0,0,0,0.35)_10%,black_22%,black_88%,transparent)] object-cover object-center sm:w-[calc(100%+8rem)] lg:w-[calc(100%+24rem)]"
    loading="eager"
    decoding="async"
  />
  <div
    class="pointer-events-none absolute inset-0 bg-gradient-to-t from-page/35 via-transparent to-page/10"
    aria-hidden="true"
  >
  </div>

  <div
    class="relative z-10 h-full min-h-0 pt-22 pb-0 sm:pt-24 lg:grid lg:min-h-full lg:grid-cols-[0.92fr_1.08fr] lg:gap-10 lg:pt-section-padding-lg"
  >
    <div
      class="relative z-20 flex max-w-[29rem] translate-y-8 flex-col justify-center py-0 sm:max-w-[33rem] sm:translate-y-0 lg:max-w-[34rem] lg:py-section-padding-main"
    >
      <div class="hero-eyebrow-entrance sm:mb-3 lg:mb-5">
        <span
          class="-rotate-3 font-script text-[clamp(1.4rem,2.8vw,2.35rem)] leading-none tracking-[0.075em] text-invitation-cream italic [text-shadow:0_2px_0_rgba(0,0,0,0.55)] sm:mb-3 lg:mb-5"
        >
          You&rsquo;re Invited To
        </span>
      </div>

      <div data-parallax="1.15">
        <div class="hero-title-entrance">
          <h1
            class="mt-5 origin-left -rotate-[2deg] transform-gpu font-display text-[clamp(5.1rem,12.8vw,9.7rem)] leading-[0.78] font-normal tracking-[-0.045em] text-pretty lg:mt-10"
          >
            <span
              class="mb-2 block -rotate-1 text-groove-coral [text-shadow:0_0.045em_0_rgba(8,9,13,0.68),0_0.1em_0.18em_rgba(0,0,0,0.5)] sm:mb-0"
            >
              Alma&rsquo;s
            </span>
            <span
              class="mb-2 block translate-x-3 rotate-1 text-groove-orange [text-shadow:0_0.045em_0_rgba(8,9,13,0.68),0_0.1em_0.18em_rgba(0,0,0,0.5)] sm:mb-0"
            >
              60th
            </span>
            <span
              class="mb-2 block -translate-x-1 -rotate-1 text-groove-mauve [text-shadow:0_0.045em_0_rgba(8,9,13,0.68),0_0.1em_0.18em_rgba(0,0,0,0.5)] sm:mb-0"
            >
              Disco
            </span>
            <span
              class="block translate-x-2 -rotate-1 text-groove-teal [text-shadow:0_0.045em_0_rgba(8,9,13,0.68),0_0.1em_0.18em_rgba(0,0,0,0.5)]"
            >
              Party
            </span>
          </h1>
        </div>
      </div>

      <div class="hero-underline-entrance">
        <svg
          class="mt-3 h-8 w-[47%] origin-left -rotate-2 overflow-visible text-pulse drop-shadow-[0_6px_10px_rgba(255,79,94,0.18)] sm:w-[31rem] lg:mt-4 lg:h-9 lg:w-[min(100%,30rem)]"
          viewBox="0 0 980 120"
          preserveAspectRatio="none"
          aria-hidden="true"
        >
          <path
            class="fill-pulse"
            d="M24 86C215 58 397 45 606 38C735 34 854 32 958 31C970 31 978 37 978 45C978 53 970 58 958 58C811 62 699 70 585 81L448 96L484 66C316 78 170 96 30 112C14 114 4 107 5 98C6 92 13 88 24 86Z"
          ></path>
        </svg>
      </div>

      <div class="hero-intro-entrance">
        <p
          class="mt-5 max-w-[14rem] font-copy leading-[1.5] font-normal text-balance text-invitation-cream [text-shadow:0_2px_0_rgba(8,9,13,0.92),0_0_10px_rgba(253,239,206,0.22)] max-sm:-rotate-5 sm:max-w-[24rem] sm:text-2xl sm:leading-tight md:text-[1.45rem] lg:mt-6"
        >
          Join us as we celebrate Alma Revales' 60th <br class="sm:hidden" />birthday!
        </p>
      </div>
    </div>

    <div
      class="absolute inset-x-0 bottom-0 z-10 flex h-[66svh] min-h-0 translate-x-8 items-end justify-end sm:translate-x-10 lg:relative lg:inset-auto lg:h-auto lg:min-h-[42rem] lg:translate-x-0"
    >
      <div
        class="pointer-events-none absolute right-[-3%] bottom-[-12%] h-[82%] w-[100%] rounded-full bg-pulse/20 blur-2xl"
        aria-hidden="true"
      >
      </div>
      <Image
        src={almaRetro}
        alt=""
        aria-hidden="true"
        class="hero-art-entrance relative z-10 max-h-[min(67.15svh,41.82rem)] w-auto max-w-[83.64%] object-contain drop-shadow-[0_20px_34px_rgba(0,0,0,0.42)] sm:max-h-[min(69.7svh,46.92rem)] sm:max-w-[75.48%] lg:max-h-[min(83.3svh,663px)] lg:max-w-[110.16%]"
        loading="eager"
        decoding="async"
      />
    </div>
  </div>
</AppSection>
