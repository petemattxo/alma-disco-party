---
import AppSection from "@/layouts/app-section.astro"

const countdownUnits = [
  {
    key: "days",
    label: "DAYS",
    color: "text-groove-mauve",
    border: "border-groove-mauve/70",
    badge: "bg-groove-mauve/35",
  },
  { key: "hours", label: "HOURS", color: "text-groove-teal", border: "border-groove-teal/70", badge: "bg-transparent" },
  { key: "minutes", label: "MINS", color: "text-pulse", border: "border-pulse/70", badge: "bg-transparent" },
  {
    key: "seconds",
    label: "SECS",
    color: "text-groove-orange",
    border: "border-groove-orange/70",
    badge: "bg-transparent",
  },
]

const countdownTarget = "2026-06-03T18:00:00+08:00"
---

<AppSection sectionId="countdown" wrapperClass="overflow-hidden bg-page" class="py-12 lg:py-16" data-countdown-section>
  <div class="mb-7 flex items-center gap-5 text-groove-mauve sm:gap-7" data-scroll-reveal>
    <span
      class="text-2xl text-pulse [text-shadow:0_0_12px_rgba(255,107,122,0.72)] max-sm:hidden"
      aria-hidden="true"
      data-parallax="0.6">✦</span
    >
    <div class="h-px min-w-8 flex-1 bg-groove-mauve/70 shadow-[0_0_10px_rgba(163,91,147,0.42)]"></div>
    <h2
      class="text-center font-countdown-heading text-[clamp(1.15rem,2.25vw,2.05rem)] leading-none font-extrabold tracking-[0.28em] text-groove-mauve uppercase [text-shadow:0_2px_0_rgba(8,9,13,0.9),0_0_10px_rgba(163,91,147,0.58)]"
      data-parallax="0.4"
    >
      Countdown To The Party
    </h2>
    <div class="h-px min-w-8 flex-1 bg-groove-mauve/70 shadow-[0_0_10px_rgba(163,91,147,0.42)]"></div>
    <span
      class="text-2xl text-pulse [text-shadow:0_0_12px_rgba(255,107,122,0.72)] max-sm:hidden"
      aria-hidden="true"
      data-parallax="0.6">✦</span
    >
  </div>

  <div
    class="relative rounded-[1.8rem] border border-[#d8b8b1]/80 bg-[#11101b] p-2 shadow-[0_0_0_2px_rgba(216,184,177,0.22),0_16px_44px_rgba(0,0,0,0.45)]"
    data-scroll-reveal="zoom"
  >
    <svg
      class="absolute top-3 left-3 h-5 w-5 text-[#d8b8b1]/70 drop-shadow-[0_0_5px_rgba(216,184,177,0.38)] sm:h-6 sm:w-6"
      viewBox="0 0 24 24"
      fill="none"
      aria-hidden="true"
    >
      <circle cx="12" cy="12" r="9" fill="#0a0b16" stroke="currentColor" stroke-width="1.8"></circle>
      <circle cx="12" cy="12" r="2.2" stroke="currentColor" stroke-width="1.4"></circle>
      <path d="M7.6 7.6L16.4 16.4M16.4 7.6L7.6 16.4" stroke="currentColor" stroke-width="1.7" stroke-linecap="round"
      ></path>
    </svg>
    <svg
      class="absolute top-3 right-3 h-5 w-5 text-[#d8b8b1]/70 drop-shadow-[0_0_5px_rgba(216,184,177,0.38)] sm:h-6 sm:w-6"
      viewBox="0 0 24 24"
      fill="none"
      aria-hidden="true"
    >
      <circle cx="12" cy="12" r="9" fill="#0a0b16" stroke="currentColor" stroke-width="1.8"></circle>
      <circle cx="12" cy="12" r="2.2" stroke="currentColor" stroke-width="1.4"></circle>
      <path d="M7.6 7.6L16.4 16.4M16.4 7.6L7.6 16.4" stroke="currentColor" stroke-width="1.7" stroke-linecap="round"
      ></path>
    </svg>
    <svg
      class="absolute bottom-3 left-3 h-5 w-5 text-[#d8b8b1]/70 drop-shadow-[0_0_5px_rgba(216,184,177,0.38)] sm:h-6 sm:w-6"
      viewBox="0 0 24 24"
      fill="none"
      aria-hidden="true"
    >
      <circle cx="12" cy="12" r="9" fill="#0a0b16" stroke="currentColor" stroke-width="1.8"></circle>
      <circle cx="12" cy="12" r="2.2" stroke="currentColor" stroke-width="1.4"></circle>
      <path d="M7.6 7.6L16.4 16.4M16.4 7.6L7.6 16.4" stroke="currentColor" stroke-width="1.7" stroke-linecap="round"
      ></path>
    </svg>
    <svg
      class="absolute right-3 bottom-3 h-5 w-5 text-[#d8b8b1]/70 drop-shadow-[0_0_5px_rgba(216,184,177,0.38)] sm:h-6 sm:w-6"
      viewBox="0 0 24 24"
      fill="none"
      aria-hidden="true"
    >
      <circle cx="12" cy="12" r="9" fill="#0a0b16" stroke="currentColor" stroke-width="1.8"></circle>
      <circle cx="12" cy="12" r="2.2" stroke="currentColor" stroke-width="1.4"></circle>
      <path d="M7.6 7.6L16.4 16.4M16.4 7.6L7.6 16.4" stroke="currentColor" stroke-width="1.7" stroke-linecap="round"
      ></path>
    </svg>
    <div class="rounded-[1.35rem] border border-[#d8b8b1]/45 p-4 shadow-[inset_0_0_0_2px_rgba(8,9,13,0.74)] sm:p-6">
      <div
        class="grid items-center gap-5 rounded-[2.5rem] border border-groove-teal/45 bg-[#0a0b16] px-4 py-7 shadow-[inset_0_0_0_2px_rgba(216,184,177,0.2)] sm:px-7 lg:grid-cols-[7rem_1fr_7rem] lg:rounded-[5rem]"
      >
        <div class="mx-auto" aria-hidden="true" data-parallax="0.55">
          <svg
            class="h-18 w-18 text-[#d8b8b1] motion-safe:animate-[spin_4s_linear_infinite] lg:h-[5.8rem] lg:w-[5.8rem]"
            viewBox="0 0 100 100"
            fill="none"
          >
            <circle cx="50" cy="50" r="36" stroke="currentColor" stroke-width="4.5"></circle>
            <circle cx="50" cy="50" r="30.5" stroke="currentColor" stroke-width="3.2"></circle>
            <rect x="47" y="19" width="6" height="12" rx="2.2" fill="currentColor" transform="rotate(0 50 50)"></rect>
            <rect x="47" y="19" width="6" height="12" rx="2.2" fill="currentColor" transform="rotate(60 50 50)"></rect>
            <rect x="47" y="19" width="6" height="12" rx="2.2" fill="currentColor" transform="rotate(120 50 50)"></rect>
            <rect x="47" y="19" width="6" height="12" rx="2.2" fill="currentColor" transform="rotate(180 50 50)"></rect>
            <rect x="47" y="19" width="6" height="12" rx="2.2" fill="currentColor" transform="rotate(240 50 50)"></rect>
            <rect x="47" y="19" width="6" height="12" rx="2.2" fill="currentColor" transform="rotate(300 50 50)"></rect>
            <circle cx="50" cy="50" r="10.5"></circle>
          </svg>
        </div>

        <div class="grid w-full gap-4 lg:grid-cols-4" data-countdown data-target={countdownTarget}>
          {
            countdownUnits.map((unit) => (
              <div class="text-center">
                <div
                  class={`rounded-lg border ${unit.border} bg-[#121421] px-3 py-3 shadow-[inset_0_0_18px_rgba(0,0,0,0.7)]`}
                >
                  <span
                    class={`block font-limelight text-[clamp(3.2rem,7vw,5.45rem)] leading-none font-normal tracking-[0.08em] tabular-nums ${unit.color} [text-shadow:0_0_8.4px_currentColor]`}
                    data-countdown-value={unit.key}
                  >
                    00
                  </span>
                </div>
                <span
                  class={`mt-2 inline-block px-2 py-0.5 font-copy text-[clamp(0.78rem,1.25vw,1.1rem)] leading-none font-normal tracking-[0.28em] text-invitation-cream uppercase ${unit.badge} [text-shadow:0_2px_0_rgba(8,9,13,0.85)]`}
                >
                  {unit.label}
                </span>
              </div>
            ))
          }
        </div>

        <div class="mx-auto" aria-hidden="true" data-parallax="0.55">
          <svg
            class="h-18 w-18 text-[#d8b8b1] motion-safe:animate-[spin_4s_linear_infinite] lg:h-[5.8rem] lg:w-[5.8rem]"
            viewBox="0 0 100 100"
            fill="none"
          >
            <circle cx="50" cy="50" r="36" stroke="currentColor" stroke-width="4.5"></circle>
            <circle cx="50" cy="50" r="30.5" stroke="currentColor" stroke-width="3.2"></circle>
            <rect x="47" y="19" width="6" height="12" rx="2.2" fill="currentColor" transform="rotate(0 50 50)"></rect>
            <rect x="47" y="19" width="6" height="12" rx="2.2" fill="currentColor" transform="rotate(60 50 50)"></rect>
            <rect x="47" y="19" width="6" height="12" rx="2.2" fill="currentColor" transform="rotate(120 50 50)"></rect>
            <rect x="47" y="19" width="6" height="12" rx="2.2" fill="currentColor" transform="rotate(180 50 50)"></rect>
            <rect x="47" y="19" width="6" height="12" rx="2.2" fill="currentColor" transform="rotate(240 50 50)"></rect>
            <rect x="47" y="19" width="6" height="12" rx="2.2" fill="currentColor" transform="rotate(300 50 50)"></rect>
            <circle cx="50" cy="50" r="10.5"></circle>
          </svg>
        </div>
      </div>
      <div class="hidden px-3 pt-5 pb-1 text-center sm:px-6 sm:pt-6" data-countdown-party-note aria-live="polite">
        <p
          class="font-countdown-heading text-[clamp(1rem,2.3vw,1.85rem)] leading-tight font-extrabold tracking-[0.18em] text-groove-orange uppercase [text-shadow:0_2px_0_rgba(8,9,13,0.9),0_0_14px_rgba(231,121,67,0.32)]"
        >
          The party is happening now!
        </p>
      </div>
    </div>
  </div>
  <script>
    const countdownSection = document.querySelector("[data-countdown-section]")
    const countdown = document.querySelector("[data-countdown]")
    const partyNote = document.querySelector("[data-countdown-party-note]")
    const formatCountdownValue = (value) => String(value).padStart(2, "0")
    const reduceMotion = window.matchMedia("(prefers-reduced-motion: reduce)")

    const launchCountdownConfetti = () => {
      if (reduceMotion.matches) return

      const canvas = document.createElement("canvas")
      const context = canvas.getContext("2d")
      if (!context) return

      const colors = ["#ff6b7a", "#f6c96b", "#7ce7f2", "#9a5f90", "#fdefce"]
      const particles = Array.from({ length: 150 }, () => ({
        x: window.innerWidth * (0.18 + Math.random() * 0.64),
        y: window.innerHeight * (0.22 + Math.random() * 0.18),
        size: Math.random() * 7 + 4,
        color: colors[Math.floor(Math.random() * colors.length)],
        velocityX: (Math.random() - 0.5) * 10,
        velocityY: Math.random() * -8 - 3,
        gravity: Math.random() * 0.14 + 0.16,
        rotation: Math.random() * Math.PI,
        spin: (Math.random() - 0.5) * 0.3,
      }))

      canvas.className = "pointer-events-none fixed inset-0 z-[100]"
      canvas.width = window.innerWidth
      canvas.height = window.innerHeight
      document.body.append(canvas)

      let frame = 0
      const animate = () => {
        frame += 1
        context.clearRect(0, 0, canvas.width, canvas.height)

        particles.forEach((particle) => {
          particle.x += particle.velocityX
          particle.y += particle.velocityY
          particle.velocityY += particle.gravity
          particle.rotation += particle.spin

          context.save()
          context.translate(particle.x, particle.y)
          context.rotate(particle.rotation)
          context.fillStyle = particle.color
          context.fillRect(-particle.size / 2, -particle.size / 2, particle.size, particle.size * 0.55)
          context.restore()
        })

        if (frame < 120) {
          window.requestAnimationFrame(animate)
          return
        }

        canvas.remove()
      }

      animate()
    }

    if (countdown instanceof HTMLElement) {
      const target = new Date(countdown.dataset.target || "2026-06-03T18:00:00+08:00").getTime()
      const values = {
        days: countdown.querySelector('[data-countdown-value="days"]'),
        hours: countdown.querySelector('[data-countdown-value="hours"]'),
        minutes: countdown.querySelector('[data-countdown-value="minutes"]'),
        seconds: countdown.querySelector('[data-countdown-value="seconds"]'),
      }
      let isExpired = false
      let hasLaunchedConfetti = false
      let isCountdownVisible = !("IntersectionObserver" in window)

      const showPartyNote = () => {
        if (partyNote instanceof HTMLElement) partyNote.classList.remove("hidden")
      }

      const launchConfettiIfReady = () => {
        if (!isExpired || !isCountdownVisible || hasLaunchedConfetti) return
        hasLaunchedConfetti = true
        launchCountdownConfetti()
      }

      const updateCountdown = () => {
        const distance = Math.max(0, target - Date.now())
        const days = Math.floor(distance / 86_400_000)
        const hours = Math.floor((distance % 86_400_000) / 3_600_000)
        const minutes = Math.floor((distance % 3_600_000) / 60_000)
        const seconds = Math.floor((distance % 60_000) / 1_000)

        if (values.days) values.days.textContent = formatCountdownValue(days)
        if (values.hours) values.hours.textContent = formatCountdownValue(hours)
        if (values.minutes) values.minutes.textContent = formatCountdownValue(minutes)
        if (values.seconds) values.seconds.textContent = formatCountdownValue(seconds)

        if (distance === 0) {
          isExpired = true
          showPartyNote()
          launchConfettiIfReady()
        }
      }

      updateCountdown()
      const interval = window.setInterval(() => {
        updateCountdown()
        if (isExpired) window.clearInterval(interval)
      }, 1_000)

      if ("IntersectionObserver" in window && countdownSection instanceof HTMLElement) {
        const countdownObserver = new IntersectionObserver(
          (entries) => {
            if (!entries.some((entry) => entry.isIntersecting)) return
            isCountdownVisible = true
            launchConfettiIfReady()
          },
          { threshold: 0.45 },
        )

        countdownObserver.observe(countdownSection)
      }
    }
  </script>
</AppSection>
