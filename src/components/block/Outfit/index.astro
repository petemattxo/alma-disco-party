---
import discoIcon from "@/assets/outfit/disco.png?url"
import moneyBagIcon from "@/assets/icons/money-bag-icon.png?url"
import outfitPopupImage from "@/assets/outfit/outfit-popup.png?url"
import pantsIcon from "@/assets/outfit/pants.png?url"
import shadesIcon from "@/assets/outfit/shades.png?url"
import shoesIcon from "@/assets/outfit/shoes.png?url"
import AppSection from "@/layouts/app-section.astro"

const outfitItems = [
  {
    icon: shadesIcon,
    title: "Neon Touches",
    description: "Bright accents and bold colors",
    card: "bg-[#2c1f44] border-groove-mauve/90",
    glow: "shadow-[0_0_24px_rgba(163,91,147,0.34)]",
    iconClass: "h-14 w-auto sm:h-24",
  },
  {
    icon: discoIcon,
    title: "Sparkle & Shine",
    description: "Sequins, glitter and shimmer",
    card: "bg-groove-teal border-cyan/70",
    glow: "shadow-[0_0_24px_rgba(108,168,173,0.34)]",
    iconClass: "h-14 w-auto sm:h-24",
  },
  {
    icon: pantsIcon,
    title: "Groovy Styles",
    description: "Bell bottoms, wraps & prints",
    card: "bg-pulse border-groove-orange/80",
    glow: "shadow-[0_0_24px_rgba(255,107,122,0.3)]",
    iconClass: "h-14 w-auto sm:h-24",
  },
  {
    icon: shoesIcon,
    title: "Comfy & Cool",
    description: "Comfortable and retro shoes",
    card: "bg-[#2c1f44] border-groove-mauve/90",
    glow: "shadow-[0_0_24px_rgba(163,91,147,0.34)]",
    iconClass: "h-14 w-auto sm:h-24",
  },
]
---

<AppSection sectionId="outfit" wrapperClass="overflow-hidden bg-page" class="py-10 sm:py-12 lg:py-16">
  <div class="mb-2 flex items-center gap-2 text-groove-mauve sm:gap-7" data-scroll-reveal>
    <span
      class="text-2xl text-pulse [text-shadow:0_0_12px_rgba(255,107,122,0.72)]"
      aria-hidden="true"
      data-parallax="0.7">✦</span
    >
    <div class="h-px min-w-8 flex-1 bg-groove-mauve/70 shadow-[0_0_10px_rgba(163,91,147,0.42)]"></div>
    <h2
      class="text-center font-countdown-heading text-[clamp(1rem,5.2vw,1.42rem)] leading-none font-extrabold tracking-[0.18em] text-groove-mauve uppercase [text-shadow:0_2px_0_rgba(8,9,13,0.9),0_0_10px_rgba(163,91,147,0.58)] sm:text-[clamp(1.15rem,2.25vw,2.05rem)] sm:tracking-[0.32em]"
      data-parallax="0.4"
    >
      Outfit Guide
    </h2>
    <div class="h-px min-w-8 flex-1 bg-groove-mauve/70 shadow-[0_0_10px_rgba(163,91,147,0.42)]"></div>
    <span
      class="text-2xl text-pulse [text-shadow:0_0_12px_rgba(255,107,122,0.72)]"
      aria-hidden="true"
      data-parallax="0.7">✦</span
    >
  </div>

  <div class="mb-5 text-center sm:mb-5" data-scroll-reveal>
    <p
      class="font-copy text-[clamp(0.95rem,1.35vw,1.25rem)] leading-tight font-normal text-invitation-cream/85 [text-shadow:0_2px_0_rgba(8,9,13,0.9)]"
    >
      Come dressed for the dance floor!
    </p>
    <div class="relative mx-auto mt-4 w-full max-w-[48rem] min-w-0 px-0 sm:px-16">
      <!-- <img
        src={moneyBagIcon}
        alt=""
        aria-hidden="true"
        class="absolute top-1/2 left-0 z-20 h-10 w-10 -translate-y-1/2 object-contain drop-shadow-[0_0_10px_rgba(246,201,107,0.34)] sm:h-12 sm:w-12"
      /> -->
      <!-- <img
        src={moneyBagIcon}
        alt=""
        aria-hidden="true"
        class="absolute top-1/2 right-0 z-20 h-10 w-10 -translate-y-1/2 object-contain drop-shadow-[0_0_10px_rgba(246,201,107,0.34)] sm:h-12 sm:w-12"
      /> -->
      <div
        class="relative flex min-h-12 max-w-full items-center overflow-hidden rounded-full border-2 border-groove-orange/80 bg-[#0d0e19] px-3 py-4 shadow-[0_0_0_1px_rgba(231,121,67,0.14),0_0_24px_rgba(231,121,67,0.16),inset_0_0_18px_rgba(253,239,206,0.05)] sm:min-h-11 sm:px-4 sm:py-3"
        aria-label="Dress to impress, cash prizes await. Top 3 outfits take home cash."
      >
        <div
          class="pointer-events-none absolute inset-x-5 top-1 h-1 bg-[radial-gradient(circle,rgba(246,201,107,0.92)_1px,transparent_2px)] [background-size:18px_4px] motion-safe:animate-pulse"
          aria-hidden="true"
        >
        </div>
        <div
          class="pointer-events-none absolute inset-x-5 bottom-1 h-1 bg-[radial-gradient(circle,rgba(246,201,107,0.72)_1px,transparent_2px)] [background-size:18px_4px] motion-safe:animate-pulse"
          aria-hidden="true"
        >
        </div>
        <div class="outfit-prize-mobile-viewport relative z-10 h-5 w-full min-w-0 overflow-hidden py-1 sm:hidden">
          <span
            class="outfit-prize-mobile-marquee absolute top-1/2 left-0 font-countdown-heading text-base leading-none font-extrabold tracking-[0.04em] whitespace-nowrap text-groove-orange uppercase [text-shadow:0_2px_0_rgba(8,9,13,0.85),0_0_8px_rgba(231,121,67,0.24)]"
            aria-hidden="true"
          >
            <span class="text-champagne">✦</span> Dress to impress, cash prizes await <span class="text-champagne"
              >✦</span
            > Top 3 outfits win cash
            <span class="text-champagne">✦</span>
          </span>
        </div>

        <div class="relative z-10 hidden w-full min-w-0 overflow-hidden py-1 sm:block">
          <div
            class="outfit-prize-marquee flex w-max max-w-none items-center gap-5 font-countdown-heading text-base leading-[1.2] font-extrabold tracking-[0.03em] whitespace-nowrap text-groove-orange uppercase [text-shadow:0_2px_0_rgba(8,9,13,0.85),0_0_8px_rgba(231,121,67,0.24)] sm:gap-8 sm:text-[clamp(0.82rem,1.35vw,1.18rem)] sm:leading-none sm:tracking-[0.12em]"
            aria-hidden="true"
          >
            {
              Array.from({ length: 4 }).map(() => (
                <span class="flex shrink-0 items-center gap-2.5 sm:gap-4">
                  <span class="text-champagne">✦</span>
                  <span>Dress to impress, cash prizes await</span>
                  <span class="text-champagne">✦</span>
                  <span>Top 3 outfits take home cash</span>
                  <span class="text-champagne">✦</span>
                </span>
              ))
            }
          </div>
        </div>
      </div>
    </div>
  </div>

  <div class="grid grid-cols-2 gap-3 sm:gap-4 xl:grid-cols-4" data-scroll-stagger>
    {
      outfitItems.map((item) => (
        <article class={`rounded-xl border-2 ${item.card} p-1 ${item.glow}`} data-scroll-reveal="zoom">
          <div class="flex min-h-[12.5rem] flex-col items-center justify-center rounded-lg border border-ink/45 px-2.5 py-4 text-center shadow-[inset_0_0_18px_rgba(255,255,255,0.08),inset_0_-16px_28px_rgba(8,9,13,0.18)] sm:min-h-[14.25rem] sm:px-4 sm:py-5">
            <img
              src={item.icon}
              alt=""
              aria-hidden="true"
              class={`${item.iconClass} mb-3 object-contain drop-shadow-[0_8px_10px_rgba(8,9,13,0.35)] sm:mb-4`}
              data-parallax="0.75"
            />
            <h3 class="font-countdown-heading text-[clamp(0.82rem,3vw,1rem)] leading-[1.05] font-extrabold tracking-[0.06em] text-balance text-invitation-cream uppercase [text-shadow:0_2px_0_rgba(8,9,13,0.255)] sm:text-[clamp(1rem,1.45vw,1.22rem)] sm:leading-none sm:tracking-[0.08em]">
              {item.title}
            </h3>
            <p class="mt-2 max-w-[8rem] font-copy text-[clamp(0.82rem,2.8vw,0.95rem)] leading-[1.22] font-normal text-balance text-invitation-cream [text-shadow:0_2px_0_rgba(8,9,13,0.216)] sm:mt-3 sm:max-w-[11rem] sm:text-[clamp(0.95rem,1.25vw,1.12rem)]">
              {item.description}
            </p>
          </div>
        </article>
      ))
    }
  </div>

  <div class="mt-6 text-center sm:mt-7">
    <button
      type="button"
      class="inline-flex max-w-full cursor-pointer items-center justify-center gap-2 rounded-full border border-groove-orange/80 bg-groove-orange/18 px-4 py-3 font-countdown-heading text-[clamp(0.85rem,1.15vw,1.05rem)] leading-none font-extrabold tracking-[0.12em] text-invitation-cream uppercase shadow-[0_0_16px_rgba(231,121,67,0.18),inset_0_0_0_1px_rgba(253,239,206,0.14)] transition-[transform,box-shadow,background-color,color] duration-200 hover:-translate-y-0.5 hover:bg-groove-orange hover:text-ink hover:shadow-[0_0_22px_rgba(231,121,67,0.34),inset_0_0_0_1px_rgba(253,239,206,0.24)] focus-visible:-translate-y-0.5 focus-visible:bg-groove-orange focus-visible:text-ink focus-visible:shadow-[0_0_22px_rgba(231,121,67,0.34),inset_0_0_0_1px_rgba(253,239,206,0.24)] sm:gap-3 sm:px-6 sm:tracking-[0.18em]"
      data-outfit-modal-open
    >
      <span aria-hidden="true">✦</span>
      View Outfit Ideas
    </button>
  </div>

  <dialog
    class="m-auto max-h-[96dvh] w-[calc(100vw-0.125rem)] max-w-none overflow-y-auto rounded-[0.75rem] border border-groove-mauve/70 bg-[#0a0b16] p-0.5 text-event-primary shadow-[0_24px_80px_rgba(0,0,0,0.72)] backdrop:bg-page/80 backdrop:backdrop-blur-sm sm:max-h-[92dvh] sm:w-[min(92vw,62rem)] sm:rounded-[1.35rem] sm:p-2"
    data-outfit-modal
    aria-label="Outfit inspiration mood board"
  >
    <div class="relative overflow-hidden rounded-[0.75rem] border border-groove-mauve/45 bg-page sm:rounded-[1rem]">
      <button
        type="button"
        class="absolute top-2 right-2 z-10 grid h-11 w-11 place-items-center rounded-full border border-invitation-cream/35 bg-page/85 font-copy text-2xl leading-none text-invitation-cream shadow-[0_6px_18px_rgba(0,0,0,0.35)] transition-[color,transform,box-shadow] duration-200 hover:scale-110 hover:text-groove-orange hover:shadow-[0_0_18px_rgba(231,121,67,0.34)] focus-visible:scale-110 focus-visible:text-groove-orange focus-visible:shadow-[0_0_18px_rgba(231,121,67,0.34)] sm:top-3 sm:right-3 sm:h-10 sm:w-10"
        data-outfit-modal-close
        aria-label="Close outfit inspirations"
      >
        ×
      </button>
      <img
        src={outfitPopupImage}
        alt="Alma's 60th disco outfit mood board with guest outfit ideas including wrap dress, jumpsuit, sequin top, retro print, velvet blazer, retro shirt, shimmer dress, and smart retro looks."
        class="h-auto w-full max-w-none object-contain sm:max-h-[88svh]"
      />
    </div>
  </dialog>
</AppSection>

<script>
  const outfitModal = document.querySelector("[data-outfit-modal]")
  const outfitModalOpen = document.querySelector("[data-outfit-modal-open]")
  const outfitModalClose = document.querySelector("[data-outfit-modal-close]")

  if (outfitModal instanceof HTMLDialogElement) {
    outfitModalOpen?.addEventListener("click", () => {
      outfitModal.showModal()
    })

    outfitModalClose?.addEventListener("click", () => {
      outfitModal.close()
    })

    outfitModal.addEventListener("click", (event) => {
      if (event.target === outfitModal) outfitModal.close()
    })
  }
</script>
