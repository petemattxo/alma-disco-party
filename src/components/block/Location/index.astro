---
import { Image } from "astro:assets"

import buildingArtwork from "@/assets/location/building.png"
import carIcon from "@/assets/location/car.png"
import discoBallIcon from "@/assets/location/disco.png"
import locationMap from "@/assets/location/location-map.png"
import AppSection from "@/layouts/app-section.astro"
---

<AppSection sectionId="location" wrapperClass="overflow-hidden bg-page" class="max-w-328 py-12 lg:py-16">
  <div
    class="rounded-[2rem] border-2 border-pulse/70 bg-[#090b16] p-4 shadow-[0_0_0_1px_rgba(255,107,122,0.162),0_0_34px_rgba(255,107,122,0.18),0_22px_70px_rgba(0,0,0,0.55)] sm:p-6"
  >
    <div
      class="relative overflow-hidden rounded-[1.55rem] border border-groove-mauve/45 px-4 pt-7 pb-5 sm:px-8 sm:pt-9"
    >
      <div
        class="pointer-events-none absolute inset-0 bg-[radial-gradient(circle_at_70%_4%,rgba(143,92,255,0.144),transparent_32%),radial-gradient(circle_at_9%_13%,rgba(255,107,122,0.144),transparent_26%)]"
        aria-hidden="true"
      >
      </div>

      <div class="relative grid items-center gap-3 lg:grid-cols-[1fr_auto]">
        <div>
          <div class="flex items-center gap-4">
            <span
              class="text-2xl text-pulse [text-shadow:0_0_12px_rgba(255,107,122,0.648)]"
              aria-hidden="true"
              data-parallax="0.65">✦</span
            >
            <h2
              class="font-rsvp text-[clamp(1.925rem,4.9vw,4.025rem)] leading-none font-normal tracking-[-0.04em] text-groove-coral uppercase [text-shadow:0_4px_0_rgba(8,9,13,0.9),0_0_18px_rgba(223,92,99,0.405)]"
              data-parallax="0.55"
            >
              Location <span class="text-groove-mauve">Guide</span>
            </h2>
          </div>

          <p
            class="mt-3 text-center font-copy text-[clamp(0.805rem,1.68vw,1.295rem)] leading-tight font-normal text-invitation-cream [text-shadow:0_2px_0_rgba(8,9,13,0.9)] sm:text-left"
          >
            Venue: <span class="text-groove-teal">JEG Tower, Sienna Function Hall</span>
          </p>
        </div>

        <div
          class="mx-auto grid h-20 w-20 place-items-center text-pulse lg:h-28 lg:w-28"
          aria-hidden="true"
          data-parallax="0.75"
        >
          <div class="relative h-full w-full [text-shadow:0_0_14px_rgba(255,107,122,0.648)]">
            <span class="absolute top-1 left-1 text-3xl lg:text-4xl">✦</span>
            <span class="absolute top-8 right-0 text-xl text-groove-mauve lg:top-10 lg:text-2xl">✦</span>
            <span class="absolute bottom-1 left-8 text-2xl text-groove-orange lg:left-10 lg:text-3xl">✦</span>
          </div>
        </div>
      </div>

      <div
        class="location-map relative mt-6 aspect-square w-full overflow-hidden rounded-[1.35rem] border-2 border-pulse/70 shadow-[0_0_24px_rgba(255,107,122,0.252)] md:aspect-5/3"
      >
        <Image
          src={locationMap}
          alt="Map showing JEG Tower near Archbishop Reyes Avenue, Hotel Elizabeth Cebu, Ayala Terraces, and nearby streets."
          class="h-full w-full object-cover"
          loading="lazy"
          decoding="async"
        />
      </div>

      <div
        class="relative mt-5 grid gap-5 rounded-[1.35rem] border-2 border-pulse/70 px-5 py-5 shadow-[0_0_22px_rgba(255,107,122,0.216)] lg:grid-cols-[1.2fr_1fr] lg:px-8"
      >
        <div class="grid gap-4 sm:grid-cols-[10rem_1fr] sm:items-center">
          <div
            class="relative aspect-square overflow-hidden rounded-xl border border-groove-coral/45 bg-[#0b1220] max-md:hidden"
            aria-hidden="true"
          >
            <Image
              src={buildingArtwork}
              alt=""
              class="h-full w-full object-cover"
              widths={[160, 240, 320]}
              sizes="(min-width: 640px) 10rem, 100vw"
              loading="lazy"
              decoding="async"
            />
          </div>
          <div>
            <h3
              class="font-rsvp text-[clamp(1.512rem,2.88vw,2.412rem)] leading-none font-normal text-groove-coral [text-shadow:0_3px_0_rgba(8,9,13,0.9)]"
            >
              JEG Tower
            </h3>
            <div class="mt-2 h-1 w-64 max-w-full border-t-4 border-dotted border-groove-coral"></div>
            <p class="mt-4 font-copy text-[clamp(0.864rem,1.44vw,1.224rem)] leading-tight text-groove-teal">
              Near Ayala Center Cebu
            </p>
            <p class="mt-2 font-copy text-[clamp(0.72rem,1.2672vw,1.0656rem)] leading-tight text-invitation-cream">
              In front of<br />Hotel Elizabeth Cebu
            </p>
          </div>
        </div>

        <div class="border-t border-pulse/55 pt-5 lg:border-t-0 lg:border-l lg:pt-0 lg:pl-8">
          <div class="flex items-center gap-4">
            <Image
              src={carIcon}
              alt=""
              class="h-16 w-16 rounded-full object-cover"
              widths={[64, 96, 128]}
              sizes="4rem"
              loading="lazy"
              decoding="async"
              aria-hidden="true"
              data-parallax="0.55"
            />
            <div class="min-w-0 flex-1">
              <h3
                class="font-countdown-heading text-[clamp(1.08rem,1.872vw,1.728rem)] leading-none font-extrabold tracking-[0.08em] text-groove-teal uppercase"
              >
                Parking Notes
              </h3>
              <div class="mt-2 h-1 w-80 max-w-full border-t-4 border-dotted border-groove-coral"></div>
            </div>
          </div>
          <p class="mt-4 font-copy text-[clamp(0.864rem,1.44vw,1.224rem)] leading-tight text-groove-orange">
            Limited parking spots only
          </p>
          <p class="mt-2 font-copy text-[clamp(0.6912rem,1.152vw,0.9792rem)] leading-tight text-invitation-cream">
            More parking spaces<br />available in front of Ayala
          </p>
        </div>
      </div>

      <div
        class="relative mt-5 flex items-center justify-center gap-4 rounded-[1.6rem] border-2 border-groove-mauve/80 px-5 py-4 text-center shadow-[0_0_22px_rgba(163,91,147,0.252)] sm:gap-6"
      >
        <Image
          src={discoBallIcon}
          alt=""
          class="hidden h-[4.992rem] w-[4.992rem] shrink-0 rounded-full object-cover sm:block lg:h-[6.24rem] lg:w-[6.24rem]"
          widths={[80, 100, 150]}
          sizes="(min-width: 1024px) 6.24rem, 4.992rem"
          loading="lazy"
          decoding="async"
          aria-hidden="true"
          data-parallax="0.6"
        />
        <p
          class="font-location-script text-[clamp(1.196rem,2.6vw,2.444rem)] leading-none font-normal text-groove-coral [text-shadow:0_2px_0_rgba(8,9,13,0.9),0_0_14px_rgba(223,92,99,0.378)]"
        >
          Follow the pin to the party!
        </p>
      </div>
    </div>
  </div>
</AppSection>
