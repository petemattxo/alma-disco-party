---
import { Image } from "astro:assets"

import buildingArtwork from "@/assets/location/building.png"
import carIcon from "@/assets/location/car.png"
import discoBallIcon from "@/assets/location/disco.png"
import locationMap from "@/assets/location/location-map.png"
import AppSection from "@/layouts/app-section.astro"
---

<AppSection sectionId="location" wrapperClass="overflow-hidden bg-page" class="max-w-328 py-12 lg:py-16">
  <div
    class="rounded-[2rem] border-2 border-pulse/70 bg-[#090b16] p-4 shadow-[0_0_0_1px_rgba(255,107,122,0.162),0_0_34px_rgba(255,107,122,0.18),0_22px_70px_rgba(0,0,0,0.55)] sm:p-6"
    data-scroll-reveal="zoom"
  >
    <div
      class="relative overflow-hidden rounded-[1.55rem] border border-groove-mauve/45 px-4 pt-7 pb-5 sm:px-8 sm:pt-9"
    >
      <div
        class="pointer-events-none absolute inset-0 bg-[radial-gradient(circle_at_70%_4%,rgba(143,92,255,0.144),transparent_32%),radial-gradient(circle_at_9%_13%,rgba(255,107,122,0.144),transparent_26%)]"
        aria-hidden="true"
      >
      </div>

      <div
        class="relative grid grid-cols-[minmax(0,1fr)_3.25rem] items-start gap-3 lg:grid-cols-[1fr_auto] lg:items-center"
      >
        <div>
          <div class="flex items-center gap-3 sm:gap-4">
            <span
              class="text-2xl text-pulse [text-shadow:0_0_12px_rgba(255,107,122,0.648)]"
              aria-hidden="true"
              data-parallax="0.65">✦</span
            >
            <h2
              class="font-rsvp text-[clamp(1.925rem,4.9vw,4.025rem)] leading-none font-normal tracking-[-0.04em] text-groove-coral uppercase [text-shadow:0_4px_0_rgba(8,9,13,0.9),0_0_18px_rgba(223,92,99,0.405)]"
              data-parallax="0.55"
            >
              Location <span class="text-groove-mauve">Guide</span>
            </h2>
          </div>

          <p
            class="mt-3 text-left font-copy text-[clamp(0.805rem,1.68vw,1.295rem)] leading-tight font-normal text-invitation-cream [text-shadow:0_2px_0_rgba(8,9,13,0.9)]"
          >
            Venue: <span class="text-groove-teal">JEG Tower, Sienna Function Hall</span>
          </p>
          <p
            class="mt-2 text-left font-copy text-[clamp(0.72rem,1.15vw,0.98rem)] leading-tight font-normal text-invitation-cream/82 [text-shadow:0_2px_0_rgba(8,9,13,0.85)]"
          >
            <span class="text-champagne">Archbishop Reyes Ave, corner Acacia St</span>
          </p>
        </div>

        <div
          class="grid h-13 w-13 place-items-center justify-self-end text-pulse sm:h-20 sm:w-20 lg:h-28 lg:w-28"
          aria-hidden="true"
          data-parallax="0.75"
        >
          <div class="relative h-full w-full [text-shadow:0_0_14px_rgba(255,107,122,0.648)]">
            <span class="absolute top-1 left-1 text-xl sm:text-3xl lg:text-4xl">✦</span>
            <span class="absolute top-6 right-0 text-base text-groove-mauve sm:top-8 sm:text-xl lg:top-10 lg:text-2xl"
              >✦</span
            >
            <span
              class="absolute bottom-1 left-6 text-lg text-groove-orange sm:left-8 sm:text-2xl lg:left-10 lg:text-3xl"
              >✦</span
            >
          </div>
        </div>
      </div>

      <div
        class="location-map relative mt-6 aspect-square w-full overflow-hidden rounded-[1.35rem] border-2 border-pulse/70 shadow-[0_0_24px_rgba(255,107,122,0.252)] md:aspect-5/3"
        data-scroll-reveal
      >
        <Image
          src={locationMap}
          alt="Map showing JEG Tower near Archbishop Reyes Avenue, Hotel Elizabeth Cebu, Ayala Terraces, and nearby streets."
          class="h-full w-full object-cover"
          loading="lazy"
          decoding="async"
        />
        <a
          href="https://maps.app.goo.gl/HVvKLfU2xcmXs17v5"
          target="_blank"
          rel="noreferrer"
          class="absolute right-3 bottom-3 z-10 inline-flex items-center justify-center gap-2 rounded-full border border-groove-teal/70 bg-[#0d0e19]/90 px-4 py-2.5 font-countdown-heading text-[0.65rem] leading-none font-extrabold tracking-[0.18em] text-invitation-cream uppercase shadow-[0_0_16px_rgba(108,168,173,0.22),inset_0_0_0_1px_rgba(253,239,206,0.12)] backdrop-blur-sm transition-[transform,box-shadow,background-color,color] duration-200 hover:-translate-y-0.5 hover:bg-groove-teal hover:text-ink hover:shadow-[0_0_22px_rgba(108,168,173,0.38),inset_0_0_0_1px_rgba(253,239,206,0.2)] focus-visible:-translate-y-0.5 focus-visible:bg-groove-teal focus-visible:text-ink sm:right-4 sm:bottom-4 sm:gap-3 sm:px-5 sm:py-3 sm:text-xs"
        >
          <span aria-hidden="true">⌖</span>
          View in Google Maps
        </a>
      </div>

      <div
        class="relative mt-5 grid grid-cols-2 gap-4 rounded-[1.35rem] border-2 border-pulse/70 px-4 py-5 shadow-[0_0_22px_rgba(255,107,122,0.216)] sm:gap-5 sm:px-5 lg:grid-cols-[1.2fr_1fr] lg:px-8"
        data-scroll-reveal
      >
        <div class="grid gap-4 md:grid-cols-[8rem_1fr] md:items-start">
          <div
            class="relative aspect-square overflow-hidden rounded-xl border border-groove-coral/45 bg-[#0b1220] max-md:hidden"
            aria-hidden="true"
          >
            <Image
              src={buildingArtwork}
              alt=""
              class="h-full w-full object-cover"
              widths={[160, 240, 320]}
              sizes="(min-width: 768px) 8rem, 100vw"
              loading="lazy"
              decoding="async"
            />
          </div>
          <div>
            <div class="min-h-[clamp(1.2096rem,2.304vw,1.9296rem)]">
              <h3
                class="font-rsvp text-[clamp(1.2096rem,2.304vw,1.9296rem)] leading-none font-normal text-groove-coral [text-shadow:0_3px_0_rgba(8,9,13,0.9)]"
              >
                JEG Tower
              </h3>
            </div>
            <div class="mt-2 h-1 w-64 max-w-full border-t-4 border-dotted border-groove-coral"></div>
            <p class="mt-4 font-copy text-[clamp(0.864rem,1.44vw,1.224rem)] leading-tight text-groove-teal">
              Near Ayala Center Cebu
            </p>
            <p class="mt-2 font-copy text-[clamp(0.72rem,1.2672vw,1.0656rem)] leading-tight text-invitation-cream">
              In front of Hotel Elizabeth Cebu
            </p>
          </div>
        </div>

        <div class="border-l border-pulse/55 pl-4 lg:pl-8">
          <div class="relative pl-11 sm:pl-14 lg:pl-20">
            <Image
              src={carIcon}
              alt=""
              class="absolute top-0 left-0 h-9 w-9 rounded-full object-cover sm:h-11 sm:w-11 lg:h-16 lg:w-16"
              widths={[64, 96, 128]}
              sizes="(min-width: 1024px) 4rem, (min-width: 640px) 2.75rem, 2.25rem"
              loading="lazy"
              decoding="async"
              aria-hidden="true"
              data-parallax="0.55"
            />
            <div class="min-w-0 flex-1">
              <div class="min-h-[clamp(1.2096rem,2.304vw,1.9296rem)]">
                <h3
                  class="font-countdown-heading text-[clamp(0.864rem,1.4976vw,1.3824rem)] leading-none font-extrabold tracking-[0.08em] text-groove-teal uppercase"
                >
                  Parking Notes
                </h3>
              </div>
              <div class="mt-2 h-1 w-80 max-w-full border-t-4 border-dotted border-groove-coral"></div>
              <p class="mt-4 font-copy text-[clamp(0.864rem,1.44vw,1.224rem)] leading-tight text-groove-orange">
                Limited parking spots only
              </p>
              <p class="mt-2 font-copy text-[clamp(0.6912rem,1.152vw,0.9792rem)] leading-tight text-invitation-cream">
                More parking in front of Ayala
              </p>
            </div>
          </div>
        </div>
      </div>

      <div
        class="relative mt-2 flex items-center justify-center gap-3 px-4 pt-1 text-center sm:gap-4"
        data-scroll-reveal
      >
        <Image
          src={discoBallIcon}
          alt=""
          class="hidden h-14 w-14 shrink-0 rounded-full object-cover sm:block lg:h-16 lg:w-16"
          widths={[80, 100, 150]}
          sizes="(min-width: 1024px) 4rem, 3.5rem"
          loading="lazy"
          decoding="async"
          aria-hidden="true"
          data-parallax="0.6"
        />
        <p
          class="font-location-script text-[clamp(1rem,2.15vw,2rem)] leading-none font-normal text-groove-coral [text-shadow:0_2px_0_rgba(8,9,13,0.9),0_0_10px_rgba(223,92,99,0.32)]"
        >
          Follow the pin to the party!
        </p>
      </div>
    </div>
  </div>
</AppSection>
