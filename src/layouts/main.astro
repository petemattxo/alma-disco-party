---
import { Font } from "astro:assets"

import "@/styles/global.css"

const metaTitle = "Alma’s 60th Disco Party"
const metaDescription =
  "You’re invited to celebrate Alma’s 60th birthday on April 25, 2026 at 4:00 PM. Join us for a night of food, music, dancing, and retro disco fun."
const metaImage = "/og-image.jpg"
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, maximum-scale=1" />
    <Font cssVariable="--font-archivo-black" preload />
    <Font cssVariable="--font-genty-demo" preload />
    <Font cssVariable="--font-cooper-black-local" preload />
    <Font cssVariable="--font-signpainter-house-script" preload />
    <Font cssVariable="--font-yellowtail" preload />
    <Font cssVariable="--font-inter-tight" preload />
    <Font cssVariable="--font-inter" preload />
    <Font cssVariable="--font-poppins" preload />
    <Font cssVariable="--font-montserrat" preload />
    <Font cssVariable="--font-limelight" preload />
    <link rel="icon" type="image/png" href="/alma-logo.png" />
    <title>{metaTitle}</title>
    <meta name="description" content={metaDescription} />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={metaTitle} />
    <meta property="og:description" content={metaDescription} />
    <meta property="og:image" content={metaImage} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={metaTitle} />
    <meta name="twitter:description" content={metaDescription} />
    <meta name="twitter:image" content={metaImage} />
  </head>
  <body>
    <div class="global-sparkle-field" data-global-sparkles aria-hidden="true"></div>
    <slot />
    <script>
      const reducedMotionQuery = window.matchMedia("(prefers-reduced-motion: reduce)")
      const parallaxItems = Array.from(document.querySelectorAll("[data-parallax]")).filter(
        (element): element is HTMLElement => element instanceof HTMLElement,
      )

      let parallaxFrame = 0

      const resetParallax = () => {
        parallaxItems.forEach((item) => {
          item.style.removeProperty("--parallax-x")
          item.style.removeProperty("--parallax-y")
        })
      }

      const clamp = (value: number, min: number, max: number) => Math.min(Math.max(value, min), max)

      const updateParallax = () => {
        parallaxFrame = 0

        if (reducedMotionQuery.matches) {
          resetParallax()
          return
        }

        const viewportHeight = window.innerHeight || 1

        parallaxItems.forEach((item) => {
          const depth = Number(item.dataset.parallax) || 1
          const rect = item.getBoundingClientRect()
          const scrollOffset = clamp((rect.top + rect.height / 2) / viewportHeight - 0.5, -1, 1)
          const y = scrollOffset * depth * -24

          item.style.setProperty("--parallax-x", "0px")
          item.style.setProperty("--parallax-y", `${y.toFixed(2)}px`)
        })
      }

      const requestParallaxUpdate = () => {
        if (parallaxFrame) return
        parallaxFrame = window.requestAnimationFrame(updateParallax)
      }

      window.addEventListener("scroll", requestParallaxUpdate, { passive: true })
      window.addEventListener("resize", requestParallaxUpdate)
      reducedMotionQuery.addEventListener("change", requestParallaxUpdate)
      requestParallaxUpdate()

      const sparkleField = document.querySelector("[data-global-sparkles]")
      const sparkleColors = ["#fdefce", "#ff6b7a", "#f6c96b", "#7ce7f2", "#9a5f90"]
      const maxSparkles = 38

      const spawnSparkle = () => {
        if (reducedMotionQuery.matches || !(sparkleField instanceof HTMLElement)) return

        const sparkle = document.createElement("span")
        const duration = Math.random() * 900 + 1500

        sparkle.className = "global-sparkle"
        sparkle.textContent = "✦"
        sparkle.style.setProperty("--sparkle-x", `${Math.random() * 100}vw`)
        sparkle.style.setProperty("--sparkle-y", `${Math.random() * 100}vh`)
        sparkle.style.setProperty("--sparkle-size", `${Math.random() * 1.15 + 0.55}rem`)
        sparkle.style.setProperty("--sparkle-color", sparkleColors[Math.floor(Math.random() * sparkleColors.length)])
        sparkle.style.setProperty("--sparkle-duration", `${duration}ms`)
        sparkle.style.setProperty("--sparkle-rotate", `${Math.random() * 180 - 90}deg`)

        sparkleField.append(sparkle)

        while (sparkleField.childElementCount > maxSparkles) {
          sparkleField.firstElementChild?.remove()
        }

        window.setTimeout(() => sparkle.remove(), duration + 120)
      }

      for (let index = 0; index < 14; index += 1) {
        window.setTimeout(spawnSparkle, index * 120)
      }

      window.setInterval(spawnSparkle, 280)

      const revealItems = Array.from(document.querySelectorAll("[data-scroll-reveal]")).filter(
        (element): element is HTMLElement => element instanceof HTMLElement,
      )

      const revealAllItems = () => {
        revealItems.forEach((item) => item.classList.add("is-revealed"))
      }

      const setupScrollReveal = () => {
        if (!revealItems.length || reducedMotionQuery.matches) {
          document.documentElement.classList.remove("scroll-reveal-ready")
          revealAllItems()
          return
        }

        document.documentElement.classList.add("scroll-reveal-ready")

        if (!("IntersectionObserver" in window)) {
          revealAllItems()
          return
        }

        const revealObserver = new IntersectionObserver(
          (entries, observer) => {
            entries.forEach((entry) => {
              if (!entry.isIntersecting) return

              entry.target.classList.add("is-revealed")
              observer.unobserve(entry.target)
            })
          },
          {
            rootMargin: "0px 0px -12% 0px",
            threshold: 0.12,
          },
        )

        revealItems.forEach((item) => revealObserver.observe(item))
      }

      setupScrollReveal()
    </script>
  </body>
</html>
